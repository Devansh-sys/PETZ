# Normalize all text files to LF in the repo, checkout as OS-native
* text=auto

# Force these to always be LF (even on Windows)
*.java text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Keep these binary
*.png binary
*.jpg binary
*.xlsx binary
*.docx binary