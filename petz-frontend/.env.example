# Copy this file to .env (gitignored) and fill in your values.
# .env is NEVER committed to git.

# Gemini API key — get a free key at https://aistudio.google.com/apikey
GEMINI_KEY=your_gemini_api_key_here

# Optional — only needed if you change the backend URL
# API_URL=http://localhost:8081/api
# WS_URL=http://localhost:8081/api/ws
# MEDIA_URL=http://localhost:8081/api
